{
  "name": "exvex",
  "description": "Run, judge, and stress-test competitive programming solutions from one CLI.",
  "version": "0.1.5",
  "type": "module",
  "bin": {
    "exvex": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "check:dist-version": "jiti scripts/check-dist-version.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:build": "jiti scripts/test-build.ts",
    "test:pack": "bun pm pack > .exvex-pack.txt && jiti scripts/test-pack.ts",
    "test:fresh-install": "jiti scripts/test-fresh-install.ts",
    "test:smoke": "node dist/index.js --help",
    "test:e2e:live": "vitest run tests/live-e2e.test.ts",
    "prepack": "npm run build && npm run check:dist-version",
    "prepublishOnly": "npm run build && npm run check:dist-version",
    "build:watch": "tsup --watch",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "cli",
    "competitive-programming",
    "competitive-programming-tool",
    "cp",
    "judge",
    "runner",
    "sample-tests",
    "multi-language",
    "stress-testing"
  ],
  "author": "Toufiq Hasan Kiron <hello@kiron.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiron0/exvex.git"
  },
  "homepage": "https://exvex.js.org",
  "bugs": {
    "url": "https://github.com/kiron0/exvex/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
