{
  "name": "exvex",
  "description": "Run, judge, and stress-test competitive programming solutions from one CLI.",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "exvex": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:build": "bun scripts/test-build.ts",
    "test:pack": "bun pm pack --dry-run > .exvex-pack.txt && bun scripts/test-pack.ts",
    "test:smoke": "node dist/index.js --help",
    "test:e2e:live": "vitest run tests/live-e2e.test.ts",
    "build:watch": "tsup --watch",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "cli",
    "competitive-programming",
    "competitive-programming-tool",
    "cp",
    "judge",
    "runner",
    "sample-tests",
    "multi-language",
    "stress-testing"
  ],
  "author": "Toufiq Hasan Kiron <hello@kiron.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiron0/exvex.git"
  },
  "homepage": "https://exvex.js.org",
  "bugs": {
    "url": "https://github.com/kiron0/exvex/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  }
}
